# Copie ce fichier en .env (déjà ignoré par git) et renseigne tes clés.
# Sans clé Anthropic, l'app fonctionne normalement : seul le bouton
# "Analyse approfondie IA" de l'onglet Entretiens sera désactivé
# (message clair affiché, pas de plantage).

ANTHROPIC_API_KEY=key

# Optionnel, valeur par défaut : claude-sonnet-5
# ANTHROPIC_MODEL=claude-sonnet-5

# --- Base de données (migration PGlite -> Postgres managé) ---
# Career_App fait du SQL direct (pas d'appels au SDK client Supabase),
# donc c'est la chaîne de connexion Postgres qu'il faut, pas les clés
# publishable/secret/JWKS (celles-ci servent au SDK Auth/REST/Realtime,
# un mode d'accès différent qu'on n'utilise pas ici).
# Dans Supabase : Settings -> Database -> Connection string
DATABASE_URL=postgresql://postgres:[mot_de_passe]@db.mwflbmcziunnkdxxwsrk.supabase.co:5432/postgres
# --- Stripe ---
STRIPE_SECRET_KEY=key
STRIPE_PUBLISHABLE_KEY=key
STRIPE_WEBHOOK_SECRET=key
# Deux prix distincts (Dashboard -> Product catalog -> créer un produit avec un
# prix récurrent -> copier l'ID qui commence par price_...) :
STRIPE_PRICE_ID_INDIVIDUAL=price_xxx  # BtoC mensuel (4,99 €/mois)
STRIPE_PRICE_ID_SCHOOL=price_yyy      # BtoB annuel (990 €/an)

# URL du front, utilisée pour les redirections success/cancel après paiement.
# En local avec `npm run dev`, le front tourne sur 5174 (cf. package.json).
CLIENT_URL=http://127.0.0.1:5174

# --- Offres réelles (France Travail, ex-Pôle Emploi) ---
# Sans ces variables, l'app fonctionne normalement avec uniquement les offres
# de démonstration (aucune erreur, juste une liste plus courte sur la page Offres).
# Inscription gratuite sur https://francetravail.io -> créer une application
# dans le tableau de bord -> s'abonner à "API Offres d'emploi v2" dans le
# catalogue -> copier l'Identifiant et la Clé secrète.
FRANCE_TRAVAIL_CLIENT_ID=id
FRANCE_TRAVAIL_CLIENT_SECRET=key