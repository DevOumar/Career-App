{
  "name": "career-web-react",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c yellow,cyan \"npm:dev:api\" \"npm:dev:client\"",
    "dev:api": "node server/index.js",
    "dev:client": "vite --host 127.0.0.1 --port 5174 --force",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4174 --strictPort",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:semantic": "node scripts/test-semantic-matching.mjs"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.1",
    "@xenova/transformers": "^2.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jspdf": "^4.2.1",
    "mammoth": "^1.8.0",
    "pdfjs-dist": "^4.7.76",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.3.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^9.1.2",
    "jsdom": "^25.0.1",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "sharp": "^0.35.0"
  }
}